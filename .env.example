# Copy this to .env and fill in your values.

# IMAP credentials
IMAP_HOST=
IMAP_PORT=993
IMAP_EMAIL=
IMAP_PASSWORD=

# LLM — all optional, see README for full reference.
# Defaults: ollama/qwen3.5:9b for extraction and assessment, ollama/llama3.2 for triage.

# Base provider and model (used for any role that doesn't have its own override)
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen3.5:9b

# Per-role overrides
# LLM_EXTRACT_PROVIDER=ollama
# LLM_EXTRACT_MODEL=qwen3.5:9b
# LLM_TRIAGE_PROVIDER=ollama
# LLM_TRIAGE_MODEL=llama3.2
# LLM_ASSESS_PROVIDER=anthropic
# LLM_ASSESS_MODEL=claude-haiku-4-5-20251001

# API keys (only needed for the providers you use)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
